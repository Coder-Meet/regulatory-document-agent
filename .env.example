# --- Email (IMAP + SMTP) ----------------------------------------------------
# Use a Gmail account with an APP PASSWORD (NOT your normal password).
# Create one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on the account.)

EMAIL_ADDRESS=youragent@gmail.com
EMAIL_APP_PASSWORD=your16charapppassword

# IMAP (reading) — Gmail defaults shown
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# SMTP (sending) — Gmail defaults shown
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Mailbox/folder to read from
MAILBOX=INBOX

# The dedicated address people use to "talk to" the agent. Use a Gmail "+alias"
# of your account (no extra setup needed): mail to it lands in the same inbox.
# When set, ONLY emails addressed here are treated as document requests, so the
# agent ignores your regular email. Leave blank to process any parseable email.
AGENT_ADDRESS=youragent+senpilot@gmail.com

# Only inspect the N most recent matching unread emails (keeps the agent fast)
MAX_EMAILS_TO_SCAN=25

# How often to re-check the inbox when running with --loop (seconds)
POLL_INTERVAL_SECONDS=60

# --- OpenRouter (LLM) -------------------------------------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Any lightweight chat model available on OpenRouter
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Browser ----------------------------------------------------------------
# Set to "false" to watch the automation run in a visible browser window.
HEADLESS=true
